<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MauiHumanizer"
             x:Class="MauiHumanizer.OtherPage"
             x:DataType="local:OtherViewModel">
    <ContentPage.Resources>
        <local:TimeStampToHumanTimeConverter x:Key="TimeStampToHumanTimeConverter" />
        <ResourceDictionary>
            <DataTemplate x:Key="MyItemTemplate" x:DataType="local:OtherModel">
                <ContentView>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                    <Border
                        Margin="12,6"
                        Padding="8"
                        BackgroundColor="DarkGoldenrod"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid
                            RowDefinitions="31, 18.5, 44">
                            <!-- Title -->
                            <Label
                                Grid.Row="0"
                                Grid.Column="0"
                                LineBreakMode="TailTruncation"
                                Text="{Binding Title, Mode=OneTime}" />
                            <!-- Sent time -->
                            <Label
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="{Binding SentTs, Mode=OneTime, Converter={StaticResource TimeStampToHumanTimeConverter}}" />
                            <!-- Message -->
                            <Label
                                Grid.Row="2"
                                Grid.Column="0"
                                LineBreakMode="TailTruncation"
                                MaxLines="2"
                                Text="{Binding Message, Mode=OneTime}" />
                        </Grid>
                    </Border>
                </ContentView>
            </DataTemplate>
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid>
        <CollectionView
            ItemSizingStrategy="MeasureFirstItem"
            ItemTemplate="{StaticResource MyItemTemplate}"
            ItemsSource="{Binding MyItems, Mode=OneTime}"
            SelectionMode="Single">
        </CollectionView>
    </Grid>
</ContentPage>